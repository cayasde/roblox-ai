{
    "name": "rrboilerplate",
    "emitLegacyScripts": false,
    "tree": {
        "$className": "DataModel",
        "ReplicatedFirst": {
            "$path": "src/ReplicatedFirst"
        },
        "ReplicatedStorage": {
            "client": {
                "$path": "src/StarterPlayerScripts"
            },
            "libs": {
                "$path": "libs"
            },
            "netclient": {
                "$path": "remotes/netclient.luau"
            },
            "nettypes": {
                "$path": "remotes/nettypes.luau"
            },
            "stories": {
                "$path": "stories"
            },
            "pkg": {
                "$path": "roblox_packages"
            },
            "assets": {
                "$className": "Folder",
                "$ignoreUnknownInstances": true
            },
            "$path": "src/ReplicatedStorage"
        },
        "ServerScriptService": {
            "$path": "src/ServerScriptService",
            "netserver": {
                "$path": "remotes/netserver.luau"
            },
            "serverpkg": {
                "$path": "roblox_server_packages"
            }
        }
    }
}
